---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import DuotonePortrait from '../components/DuotonePortrait.astro';
import smile from '../assets/images/yannik-smile.jpg';

const email = 'yannik@kintscher.ai';
---

<Layout
  title="Contact — Yannik Kintscher"
  description="Email and social channels for Yannik Kintscher. Based in Zürich, CET, replies within a few days."
  path="/contact"
>
  <article class="contact">
    <p class="meta">
      <span class="dot" aria-hidden="true"></span>
      <span>FILE&nbsp;/&nbsp;CONTACT</span>
      <span class="sep" aria-hidden="true">/</span>
      <time datetime="2026">2026</time>
    </p>

    <div class="body">
      <div class="body-stack">
        <header class="contact-head">
          <h1 class="contact-title">
            <span class="line"><span class="line-inner"><em>Let's&nbsp;talk.</em></span></span>
          </h1>
          <p class="contact-dek">
            <span class="line-inner">I read every email.</span>
          </p>
        </header>

        <section class="email-block" aria-labelledby="email-h">
      <h2 id="email-h" class="sr-only">Primary contact</h2>
      <div class="email-row">
        <a class="email" href={`mailto:${email}`}>{email}</a>
        <button
          type="button"
          class="copy"
          data-copy={email}
          aria-label="Copy email address to clipboard"
        >
          <span class="copy-state copy-default" aria-hidden="true">
            <kbd>⌘</kbd><kbd>C</kbd>
          </span>
          <span class="copy-state copy-done" aria-hidden="true">copied.</span>
        </button>
      </div>
      <p class="availability">
        <span>Based in Zürich</span>
        <span class="dot-sep" aria-hidden="true">·</span>
        <span>CET</span>
        <span class="dot-sep" aria-hidden="true">·</span>
        <span>usually replies within a few days</span>
      </p>
    </section>

    <section class="social" aria-labelledby="social-h">
      <h2 id="social-h" class="sr-only">Other channels</h2>
      <ul class="social-list" role="list">
        <li class="social-row" data-channel="github">
          <a
            class="social-link"
            href="https://github.com/kintscher"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="social-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
            </span>
            <span class="social-label">GitHub</span>
            <span class="social-url">github.com/kintscher</span>
            <span class="social-key" aria-hidden="true">G</span>
          </a>
          <span class="social-note" aria-hidden="true">best for code</span>
        </li>

        <li class="social-row" data-channel="linkedin">
          <a
            class="social-link"
            href="https://www.linkedin.com/in/yannik-kintscher"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="social-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect width="4" height="12" x="2" y="9"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </span>
            <span class="social-label">LinkedIn</span>
            <span class="social-url">linkedin.com/in/yannik-kintscher</span>
            <span class="social-key" aria-hidden="true">L</span>
          </a>
          <span class="social-note" aria-hidden="true">best for async questions</span>
        </li>

        <li class="social-row" data-channel="instagram">
          <a
            class="social-link"
            href="https://www.instagram.com/yannik.kintscher"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="social-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
              </svg>
            </span>
            <span class="social-label">Instagram</span>
            <span class="social-url">instagram.com/yannik.kintscher</span>
            <span class="social-key" aria-hidden="true">I</span>
          </a>
          <span class="social-note" aria-hidden="true">occasional life updates</span>
        </li>
      </ul>
    </section>
      </div>

      <DuotonePortrait
        src={smile}
        caption="Self-portrait"
        year="2025"
        objectPosition="50% 22%"
        ariaLabel="Portrait of Yannik Kintscher, smiling"
        class="contact-portrait"
      />
    </div>

    <footer class="contact-foot">
      <p class="signoff"><em>— Y.</em></p>
      <a class="next-link" href="/chat">
        <span class="next-kicker">next&nbsp;/</span>
        <span class="next-label">ask yannik anything</span>
        <span class="next-arrow" aria-hidden="true">→</span>
        <span class="key-hint" aria-hidden="true">⌐ C</span>
      </a>
    </footer>
  </article>
</Layout>

<script>
  function wireCopy() {
    const btn = document.querySelector<HTMLButtonElement>('.contact .copy');
    if (!btn) return;
    if (btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';
    let resetTimer: number | undefined;

    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      if (!text) return;

      let ok = false;
      try {
        await navigator.clipboard.writeText(text);
        ok = true;
      } catch {
        // legacy fallback
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.cssText = 'position:absolute;left:-9999px;top:-9999px;';
        document.body.appendChild(ta);
        ta.select();
        try { ok = document.execCommand('copy'); } catch { ok = false; }
        ta.remove();
      }

      if (!ok) return;

      btn.classList.add('is-done');
      btn.setAttribute('aria-live', 'polite');
      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        btn.classList.remove('is-done');
      }, 1500);
    });
  }
  wireCopy();
  document.addEventListener('astro:page-load', wireCopy);
</script>

<style>
  /* ───────────────────────────── shell ───────────────────────────── */

  .contact {
    position: relative;
    max-width: 1200px;
    margin-inline: auto;
    padding: clamp(2.5rem, 6vh, 5rem) clamp(1.25rem, 3vw, 2.5rem) clamp(3rem, 7vh, 6rem);
    display: grid;
    row-gap: clamp(2rem, 4vh, 3rem);
  }

  .body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 400px);
    column-gap: clamp(2rem, 4.5vw, 4.5rem);
    align-items: start;
  }

  .body-stack {
    display: grid;
    row-gap: clamp(2.25rem, 4.5vh, 3.5rem);
    /* keep readable measure within the left column */
    max-width: 38rem;
  }

  /* warm wash, mirroring /about but tipped toward the right where the portrait sits */
  .contact::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(55% 45% at 78% 28%, rgb(232 168 58 / 0.06) 0%, transparent 70%),
      radial-gradient(45% 35% at 12% 78%, rgb(91 168 155 / 0.035) 0%, transparent 70%);
    z-index: -1;
  }

  /* ───────────────────────────── meta ───────────────────────────── */

  .meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-quiet);
    opacity: 0;
    animation: fade-up 380ms cubic-bezier(0.5, 0, 0.2, 1) 80ms both;
  }
  .meta .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-signal);
    box-shadow: 0 0 8px rgb(91 168 155 / 0.6);
    animation: pulse-signal 2.4s ease-in-out infinite;
  }
  .meta .sep { color: var(--color-quiet); opacity: 0.5; }

  /* ───────────────────────────── headline ───────────────────────────── */

  .contact-head {
    display: grid;
    gap: 1rem;
    max-width: 22ch;
  }

  .contact-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 7vw, 5.75rem);
    line-height: 0.96;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    display: flex;
    flex-direction: column;
  }
  .contact-title .line { display: block; overflow: hidden; }
  .contact-title .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) 200ms both;
  }
  .contact-title em { font-style: italic; color: var(--color-fg); }

  .contact-dek {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.05vw, 1.0625rem);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 32ch;
    overflow: hidden;
  }
  .contact-dek .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) 440ms both;
  }

  /* ───────────────────────────── portrait positioning ───────────────────────────── */

  .contact-portrait {
    align-self: start;
    opacity: 0;
    animation: fade-up 800ms cubic-bezier(0.5, 0, 0.2, 1) 600ms both;
  }

  /* ───────────────────────────── email block ───────────────────────────── */

  .email-block {
    display: grid;
    gap: 0.85rem;
    opacity: 0;
    animation: fade-up 720ms cubic-bezier(0.4, 0, 0.2, 1) 540ms both;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .email-row {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    flex-wrap: wrap;
    row-gap: 0.5rem;
  }

  .email {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.8vw, 2.5rem);
    line-height: 1.05;
    color: var(--color-fg);
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: color 200ms ease;
    /* slightly tighter measure so the @ and . feel intentional */
    font-feature-settings: "ss01", "cv11";
  }
  .email:hover,
  .email:focus-visible {
    color: var(--color-accent);
    outline: none;
  }
  .email:focus-visible {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .copy {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    background: rgb(232 168 58 / 0.04);
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    padding: 0.3rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-quiet);
    cursor: pointer;
    min-width: 4.4rem;
    line-height: 1;
    transition: color 160ms ease, border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }
  .copy:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgb(232 168 58 / 0.08);
    transform: translateY(-1px);
  }
  .copy:active { transform: translateY(0); }
  .copy kbd {
    font: inherit;
    color: inherit;
    letter-spacing: 0;
  }

  .copy-state {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .copy-default { opacity: 1; transform: translateY(0); }
  .copy-done {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-signal);
    opacity: 0;
    transform: translateY(2px);
    pointer-events: none;
  }
  .copy.is-done {
    border-color: var(--color-signal);
    background: rgb(91 168 155 / 0.08);
    color: var(--color-signal);
  }
  .copy.is-done .copy-default {
    opacity: 0;
    transform: translateY(-2px);
  }
  .copy.is-done .copy-done {
    opacity: 1;
    transform: translateY(0);
  }

  .availability {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.01em;
    color: var(--color-quiet);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
  }
  .availability .dot-sep { opacity: 0.6; }

  /* ───────────────────────────── social tier ───────────────────────────── */

  .social {
    opacity: 0;
    animation: fade-up 720ms cubic-bezier(0.4, 0, 0.2, 1) 720ms both;
  }

  .social-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    /* narrower than the body-stack so the right-margin annotations
       have room to render without colliding with the portrait */
    max-width: 26rem;
    /* hairlines via top borders; matches editorial directory feel */
    border-top: 1px solid var(--color-hairline);
  }

  .social-row {
    position: relative;
    border-bottom: 1px solid var(--color-hairline);
  }

  .social-link {
    display: grid;
    grid-template-columns: 22px max-content 1fr max-content;
    align-items: center;
    column-gap: 0.95rem;
    padding: 0.85rem 0;
    text-decoration: none;
    color: var(--color-fg);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.3;
    transition: color 160ms ease;
  }
  .social-link:focus-visible { outline-offset: 4px; }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: rgb(240 235 226 / 0.62);
    transition: color 200ms ease, transform 200ms cubic-bezier(0.5, 0, 0.2, 1);
  }
  .social-icon svg {
    width: 16px;
    height: 16px;
    display: block;
    /* uniform stroke across all three lucide glyphs — Instagram included */
    stroke-width: 1.5;
  }
  .social-link:hover .social-icon,
  .social-link:focus-visible .social-icon {
    color: var(--color-accent);
    transform: translateX(1px);
  }

  /* The label gets the nav's hover treatment: 1px underline that scales in,
     plus a 4px box-shadow rule below it (Swiss double-rule), and a 0.5px text nudge. */
  .social-label {
    position: relative;
    color: var(--color-fg);
    display: inline-block;
    transition: transform 60ms ease 140ms;
  }
  .social-label::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition:
      transform 140ms cubic-bezier(0.5, 0, 0.2, 1),
      box-shadow 50ms ease 140ms;
  }
  .social-link:hover .social-label::after,
  .social-link:focus-visible .social-label::after {
    transform: scaleX(1);
    box-shadow: 0 4px 0 var(--color-accent);
  }
  .social-link:hover .social-label,
  .social-link:focus-visible .social-label {
    transform: translateX(0.5px);
  }

  .social-url {
    color: var(--color-quiet);
    font-size: 12px;
    letter-spacing: 0.005em;
    transition: color 160ms ease;
    /* truncate gracefully on narrow widths */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .social-link:hover .social-url,
  .social-link:focus-visible .social-url {
    color: var(--color-muted);
  }

  .social-key {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0;
    color: var(--color-accent);
    border: 1px solid var(--color-hairline);
    padding: 1px 6px;
    border-radius: 3px;
    background: rgb(232 168 58 / 0.05);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity 130ms ease, transform 130ms ease, border-color 160ms ease;
  }
  .social-link:hover .social-key,
  .social-link:focus-visible .social-key {
    opacity: 1;
    transform: translateX(0);
    border-color: var(--color-accent);
  }

  /* margin annotation on the right — mirror of /about's left-margin glosses */
  .social-note {
    position: absolute;
    top: 50%;
    left: calc(100% + 1.5rem);
    transform: translateY(-50%) translateX(-4px);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13.5px;
    letter-spacing: -0.005em;
    line-height: 1.2;
    color: var(--color-muted);
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    transition: opacity 80ms ease, transform 80ms ease;
  }
  /* a tiny amber rule sits before the note, tying it to the row */
  .social-note::before {
    content: '';
    position: absolute;
    right: calc(100% + 0.55rem);
    top: 50%;
    width: 14px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.85;
    box-shadow: 0 0 6px rgb(232 168 58 / 0.3);
  }
  .social-row:hover .social-note,
  .social-row:focus-within .social-note {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  /* On narrower screens we hide the right-margin note (no room for it). */
  @media (max-width: 1099px) {
    .social-note { display: none; }
  }

  /* ───────────────────────────── foot ───────────────────────────── */

  .contact-foot {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vh, 2.25rem);
    margin-top: clamp(1rem, 2vh, 1.75rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-hairline);
    opacity: 0;
    animation: fade-up 720ms cubic-bezier(0.4, 0, 0.2, 1) 1100ms both;
  }
  .signoff {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.8vw, 1.9rem);
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .signoff em { font-style: italic; }

  .next-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 160ms ease, gap 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .next-kicker { color: var(--color-quiet); letter-spacing: 0.04em; }
  .next-label  { color: var(--color-fg); }
  .next-arrow  { color: var(--color-accent); transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1); }
  .next-link:hover { gap: 1rem; }
  .next-link:hover .next-arrow { transform: translateX(3px); }
  .next-link:hover .next-label { color: var(--color-fg); }

  /* ───────────────────────────── animations ───────────────────────────── */

  @keyframes rise { to { transform: translateY(0); } }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-signal {
    0%, 100% { box-shadow: 0 0 6px rgb(91 168 155 / 0.45); opacity: 1; }
    50%      { box-shadow: 0 0 12px rgb(91 168 155 / 0.85); opacity: 0.75; }
  }

  @media (prefers-reduced-motion: reduce) {
    .meta, .contact-title .line-inner, .contact-dek .line-inner,
    .email-block, .social, .contact-portrait, .contact-foot {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .meta .dot { animation: none; }
    .social-icon { transition: none; }
    .copy, .copy-state { transition: none; }
  }

  /* ───────────────────────────── responsive ───────────────────────────── */

  /* tablet/small laptop: stack into one column.
     Order: meta → hero → email → social → portrait → foot.
     Email lands first after the hero (the user's action priority);
     the portrait closes the page warmly before the signature. */
  @media (max-width: 900px) {
    .body {
      grid-template-columns: 1fr;
      row-gap: clamp(2rem, 4vh, 3rem);
    }
    .body-stack {
      max-width: 100%;
      row-gap: clamp(1.75rem, 3.5vh, 2.5rem);
      order: 1;
    }
    .contact-portrait {
      order: 2;
      max-width: 460px;
    }
    .contact-head { max-width: 100%; }
  }

  /* mobile: tighten, keep email clearly the largest text element */
  @media (max-width: 720px) {
    .contact { padding-top: 2rem; }
    .contact-portrait { max-width: 78vw; }
    .email-row { gap: 0.75rem; }
    .availability {
      gap: 0.4rem;
      font-size: 11.5px;
    }
    .social-url { display: none; }
    .social-link {
      grid-template-columns: 22px 1fr max-content;
      column-gap: 0.85rem;
      padding: 0.95rem 0;
    }
  }
</style>
