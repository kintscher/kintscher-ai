---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import PortraitFrame from '../components/PortraitFrame.astro';
import portrait from '../assets/images/yannik-tower.jpg';
---

<Layout
  title="Yannik Kintscher — Fullstack engineer in Zürich"
  description="Fullstack engineer in Zürich. GenAI, Conversational banking, internal tooling at UBS."
  path="/"
>
  <section class="home">
    <div class="hero">
      <p class="meta">
        <span class="dot" aria-hidden="true"></span>
        <span>47.37°N&nbsp;8.54°E</span>
        <span class="sep">/</span>
        <span>Zürich</span>
        <span class="sep">/</span>
        <span>CET</span>
      </p>

      <h1 class="hero-title">
        <span class="line"><span class="line-inner">Fullstack engineer</span></span>
        <span class="line"><span class="line-inner"><em>in Zürich.</em></span></span>
      </h1>

      <p class="hero-sub">
        <span class="line-inner">GenAI, Conversational banking,<br />internal tooling at UBS.</span>
      </p>

      <form
        class="prompt"
        id="hero-prompt-form"
        action="/chat"
        method="get"
        novalidate
        autocomplete="off"
        data-form-type="other"
        data-1p-ignore="true"
        data-lpignore="true"
        data-bwignore="true"
        data-dashlane-ignore="true"
      >
        <span class="prompt-cursor" aria-hidden="true">›</span>
        <textarea
          id="hero-prompt-input"
          name="q"
          rows="1"
          enterkeyhint="go"
          class="prompt-input"
          placeholder="ask yannik anything"
          aria-label="Ask yannik anything"
          maxlength="4000"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        ></textarea>
        <span class="prompt-key" aria-hidden="true">⌘ <kbd>/</kbd></span>
      </form>
    </div>

    <PortraitFrame
      src={portrait}
      alt="Yannik Kintscher, fullstack engineer based in Zürich"
      ariaLabel="Portrait of Yannik Kintscher"
      caption="PORTRAIT"
      index="01"
      sizes="(max-width: 720px) 38vw, (max-width: 1024px) 16vw, 210px"
      class="home-portrait"
    />
  </section>
</Layout>

<script>
  function wireHomePrompt() {
    const home = document.querySelector<HTMLElement>('.home');
    const form = document.getElementById('hero-prompt-form') as HTMLFormElement | null;
    const input = document.getElementById('hero-prompt-input') as HTMLTextAreaElement | null;
    if (!form || !input || !home) return;

    // Drop empty submissions silently. Native GET handles encoding + nav,
    // so /chat lands with ?q=... and ChatInterface auto-fires the question.
    form.addEventListener('submit', (e) => {
      const q = input.value.trim();
      if (!q) e.preventDefault();
    });

    // Textarea inserts a newline on Enter by default — submit instead so
    // the field behaves like a single-line input. Shift+Enter keeps newline.
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    // Mobile-only: when the prompt is focused, mark the section so the
    // portrait can fade out and the input becomes the user's focus.
    // The on-screen keyboard then rises smoothly under the input thanks
    // to `interactive-widget=resizes-content` on the viewport meta.
    const onFocus = () => home.setAttribute('data-prompt-focused', 'true');
    const onBlur = () => home.removeAttribute('data-prompt-focused');
    input.addEventListener('focus', onFocus);
    input.addEventListener('blur', onBlur);
  }
  wireHomePrompt();
  document.addEventListener('astro:page-load', wireHomePrompt);
</script>

<style>
  .home {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-rows: 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding: clamp(2rem, 5vh, 4rem) 2rem clamp(2rem, 5vh, 4rem);
    min-height: calc(100vh - 220px);
    max-width: 1280px;
    margin-inline: auto;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-self: center;
  }

  /* ----- Meta line ----- */

  .meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-quiet);
    opacity: 0;
    animation: fade-up 380ms cubic-bezier(0.5, 0, 0.2, 1) 80ms both;
  }
  .meta .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-signal);
    box-shadow: 0 0 8px rgb(91 168 155 / 0.6);
    animation: pulse-signal 2.4s ease-in-out infinite;
  }
  .meta .sep { color: var(--color-quiet); opacity: 0.5; }

  /* ----- Hero display type ----- */

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.75rem, 7.4vw, 6.25rem);
    line-height: 0.96;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    display: flex;
    flex-direction: column;
  }
  .hero-title .line {
    display: block;
    overflow: hidden;
  }
  .hero-title .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) both;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-fg);
  }
  .hero-title .line:nth-child(1) .line-inner { animation-delay: 180ms; }
  .hero-title .line:nth-child(2) .line-inner { animation-delay: 280ms; }

  /* ----- Standfirst ----- */

  .hero-sub {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.1vw, 1.0625rem);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 34ch;
    overflow: hidden;
  }
  .hero-sub .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) 420ms both;
  }

  /* ----- Prompt button (the thesis) ----- */

  .prompt {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    padding: 0.7rem 1rem 0.7rem 0.85rem;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    transition: border-color 180ms ease, color 180ms ease, background 180ms ease, transform 180ms ease;
    opacity: 0;
    animation: fade-up 480ms cubic-bezier(0.5, 0, 0.2, 1) 580ms both;
    min-width: min(420px, 100%);
    text-align: left;
  }
  .prompt:hover,
  .prompt:focus-within {
    border-color: var(--color-accent);
    color: var(--color-fg);
    background: var(--color-surface-2);
  }
  .prompt:hover .prompt-cursor,
  .prompt:focus-within .prompt-cursor { color: var(--color-accent); }

  .prompt-cursor {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 500;
    transform: translateY(-0.5px);
  }
  .prompt-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: inherit;
    font: inherit;
    padding: 0;
    margin: 0;
    caret-color: var(--color-accent);
    resize: none;
    overflow: hidden;
    line-height: 1.5;
    height: calc(1em * 1.5);
  }
  .prompt-input::placeholder { color: var(--color-muted); }
  .prompt-input:focus { color: var(--color-fg); }
  .prompt-input:focus-visible { outline: none; }
  .prompt-key {
    color: var(--color-quiet);
    font-size: 11px;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .prompt-key kbd {
    font-family: inherit;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
    padding: 0 5px;
    background: rgb(0 0 0 / 0.3);
    color: var(--color-muted);
  }

  /* ----- Portrait ----- */

  :global(.home-portrait) {
    align-self: center;
    width: clamp(140px, 16vw, 210px);
    opacity: 0;
    animation: fade-up 700ms cubic-bezier(0.5, 0, 0.2, 1) 700ms both;
  }

  /* ----- Animations ----- */

  @keyframes rise {
    to { transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-signal {
    0%, 100% { box-shadow: 0 0 6px rgb(91 168 155 / 0.45); opacity: 1; }
    50%      { box-shadow: 0 0 12px rgb(91 168 155 / 0.85); opacity: 0.75; }
  }

  @media (prefers-reduced-motion: reduce) {
    .meta, .hero-title .line-inner, .hero-sub .line-inner, .prompt, :global(.home-portrait) {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .meta .dot { animation: none; }
  }

  /* ----- Responsive ----- */

  @media (min-width: 721px) and (max-width: 1024px) {
    .home {
      align-items: center;
      min-height: calc(100vh - 220px);
      padding-block: clamp(2rem, 6vh, 4rem);
    }
  }

  @media (max-width: 720px) {
    .home {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      align-items: start;
      align-content: center;
      gap: 1.75rem;
      /* dvh shrinks with the on-screen keyboard (paired with
         `interactive-widget=resizes-content`), so the layout naturally
         reflows above the keyboard instead of being cropped. */
      min-height: calc(100dvh - 180px);
      padding: 1.5rem 1.25rem 2rem;
      transition: gap 320ms cubic-bezier(0.5, 0, 0.2, 1);
    }
    .hero { gap: 1.25rem; align-self: auto; }
    .hero-sub { max-width: 26ch; }
    .prompt {
      min-width: 0;
      width: 100%;
      padding: 0.85rem 1rem 0.85rem 0.95rem;
      transition:
        transform 320ms cubic-bezier(0.5, 0, 0.2, 1),
        border-color 200ms ease,
        background 200ms ease,
        box-shadow 360ms cubic-bezier(0.5, 0, 0.2, 1);
    }
    /* 16px prevents iOS Safari from auto-zooming on focus, which is
       what made the input appear to scroll off the right edge. */
    .prompt-input { font-size: 16px; }
    .prompt-key { display: none; }
    :global(.home-portrait) {
      align-self: center;
      justify-self: center;
      width: clamp(170px, 52vw, 220px);
      transition:
        opacity 360ms cubic-bezier(0.5, 0, 0.2, 1),
        transform 360ms cubic-bezier(0.5, 0, 0.2, 1),
        filter 360ms cubic-bezier(0.5, 0, 0.2, 1);
      will-change: opacity, transform, filter;
    }

    /* Focus state: collapse the portrait out of the way so the prompt
       is the user's center of attention while the keyboard rises. */
    .home[data-prompt-focused='true'] {
      gap: 1.25rem;
    }
    .home[data-prompt-focused='true'] :global(.home-portrait) {
      opacity: 0;
      transform: translateY(-12px) scale(0.96);
      filter: blur(2px);
      pointer-events: none;
    }
    .home[data-prompt-focused='true'] .prompt {
      transform: translateY(-2px);
      box-shadow: 0 14px 38px -22px rgb(0 0 0 / 0.55);
    }
  }

  @media (max-width: 720px) and (prefers-reduced-motion: reduce) {
    .home,
    .prompt,
    :global(.home-portrait) { transition: none; }
    .home[data-prompt-focused='true'] :global(.home-portrait) {
      transform: none;
      filter: none;
    }
    .home[data-prompt-focused='true'] .prompt { transform: none; }
  }

  @media (hover: none) {
    .prompt-key { display: none; }
  }
</style>
