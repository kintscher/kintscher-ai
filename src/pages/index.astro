---
export const prerender = true;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Kintscher.ai — Yannik Kintscher</title>
    <meta name="description" content="Yannik Kintscher — Fullstack Developer in Zürich." />

    <link rel="canonical" href="https://kintscher.ai" />

    <!-- Open Graph -->
    <meta property="og:title" content="Kintscher.ai — Yannik Kintscher" />
    <meta property="og:description" content="Yannik Kintscher — Fullstack Developer in Zürich." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kintscher.ai" />
    <meta property="og:site_name" content="Kintscher.ai" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Kintscher.ai — Yannik Kintscher" />
    <meta name="twitter:description" content="Yannik Kintscher — Fullstack Developer in Zürich." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-fg min-h-screen flex items-center justify-center pb-[8vh] px-6 py-16">

    <!-- Background grid texture -->
    <div
      aria-hidden="true"
      class="fixed inset-0 -z-10 pointer-events-none"
      style="
        background-image:
          linear-gradient(to right, #e5e7eb 1px, transparent 1px),
          linear-gradient(to bottom, #e5e7eb 1px, transparent 1px);
        background-size: 48px 48px;
        opacity: 0.03;
      "
    ></div>

    <main class="w-full max-w-3xl items-center text-center">
      <div class="flex flex-col">

        <h1
          class="font-mono text-5xl sm:text-7xl lg:text-8xl font-semibold text-fg leading-[0.95]"
          style="letter-spacing: -0.03em;"
        >
          Kintscher<span class="text-accent/70">.ai</span>
        </h1>

        <p
          class="font-sans text-xl sm:text-2xl text-muted leading-relaxed mt-8 mx-auto"
          style="max-width: 36rem; text-wrap: balance;"
        >
          Yannik Kintscher — Fullstack Developer in Zürich.
        </p>

        <nav aria-label="Social links" class="mt-14">
          <ul class="flex flex-wrap justify-center gap-x-10 gap-y-4" role="list">
            <li>
              <a
                href="https://github.com/kintscher"
                target="_blank"
                rel="noopener noreferrer"
                class="link-item"
              >
                <span>GitHub</span>
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </li>
            <li>
              <a
                href="https://linkedin.com/in/yannik-kintscher"
                target="_blank"
                rel="noopener noreferrer"
                class="link-item"
              >
                <span>LinkedIn</span>
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </li>
            <li>
              <a
                href="https://instagram.com/yannik.zh"
                target="_blank"
                rel="noopener noreferrer"
                class="link-item"
              >
                <span>Instagram</span>
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </li>
            <li>
              <a
                href="mailto:yannik@kintscher.ai"
                class="link-item"
              >
                <span>Email</span>
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          </ul>
        </nav>

      </div>
    </main>

  </body>
</html>

<style>
  .link-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .link-item:hover {
    color: #e5e7eb;
  }

  .link-item:hover .arrow {
    color: #60a5fa;
  }

  @media (min-width: 640px) {
    .link-item {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 768px) {
    .link-item {
      font-size: 1.25rem;
    }
  }

  .arrow {
    font-size: 0.75em;
    transition: color 150ms ease;
  }
</style>
