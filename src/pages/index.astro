---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import PortraitFrame from '../components/PortraitFrame.astro';
import portrait from '../assets/images/yannik-tower.jpg';
---

<Layout
  title="Yannik Kintscher — Fullstack engineer in Zürich"
  description="Fullstack engineer in Zürich. GenAI, Conversational banking, internal tooling at UBS."
  path="/"
>
  <section class="home">
    <div class="hero">
      <p class="meta">
        <span class="dot" aria-hidden="true"></span>
        <span>47.37°N&nbsp;8.54°E</span>
        <span class="sep">/</span>
        <span>Zürich</span>
        <span class="sep">/</span>
        <span>CET</span>
      </p>

      <h1 class="hero-title">
        <span class="line"><span class="line-inner">Fullstack engineer</span></span>
        <span class="line"><span class="line-inner"><em>in Zürich.</em></span></span>
      </h1>

      <p class="hero-sub">
        <span class="line-inner">GenAI, Conversational banking,<br />internal tooling at UBS.</span>
      </p>

      <button class="prompt" type="button" id="hero-prompt">
        <span class="prompt-cursor" aria-hidden="true">›</span>
        <span class="prompt-label">ask yannik anything</span>
        <span class="prompt-key" aria-hidden="true">⌘ <kbd>/</kbd></span>
      </button>
    </div>

    <PortraitFrame
      src={portrait}
      alt="Yannik Kintscher"
      ariaLabel="Portrait of Yannik"
      class="home-portrait"
    />
  </section>
</Layout>

<script>
  function wireHomePrompt() {
    const btn = document.getElementById('hero-prompt');
    if (!btn) return;
    btn.addEventListener('click', () => {
      type W = Window & { __openCmd?: () => void };
      (window as unknown as W).__openCmd?.();
    });
  }
  wireHomePrompt();
  document.addEventListener('astro:page-load', wireHomePrompt);
</script>

<style>
  .home {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-rows: 1fr;
    align-items: end;
    gap: clamp(2rem, 6vw, 5rem);
    padding: clamp(3rem, 8vh, 7rem) 2rem clamp(3rem, 8vh, 6rem);
    min-height: calc(100vh - 220px);
    max-width: 1280px;
    margin-inline: auto;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-self: end;
  }

  /* ----- Meta line ----- */

  .meta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-quiet);
    opacity: 0;
    animation: fade-up 380ms cubic-bezier(0.5, 0, 0.2, 1) 80ms both;
  }
  .meta .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-signal);
    box-shadow: 0 0 8px rgb(91 168 155 / 0.6);
    animation: pulse-signal 2.4s ease-in-out infinite;
  }
  .meta .sep { color: var(--color-quiet); opacity: 0.5; }

  /* ----- Hero display type ----- */

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.75rem, 7.4vw, 6.25rem);
    line-height: 0.96;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    display: flex;
    flex-direction: column;
  }
  .hero-title .line {
    display: block;
    overflow: hidden;
  }
  .hero-title .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) both;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-fg);
  }
  .hero-title .line:nth-child(1) .line-inner { animation-delay: 180ms; }
  .hero-title .line:nth-child(2) .line-inner { animation-delay: 280ms; }

  /* ----- Standfirst ----- */

  .hero-sub {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.1vw, 1.0625rem);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 34ch;
    overflow: hidden;
  }
  .hero-sub .line-inner {
    display: inline-block;
    transform: translateY(105%);
    animation: rise 720ms cubic-bezier(0.2, 0.7, 0, 1) 420ms both;
  }

  /* ----- Prompt button (the thesis) ----- */

  .prompt {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    padding: 0.7rem 1rem 0.7rem 0.85rem;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease, background 180ms ease, transform 180ms ease;
    opacity: 0;
    animation: fade-up 480ms cubic-bezier(0.5, 0, 0.2, 1) 580ms both;
    min-width: min(420px, 100%);
    text-align: left;
  }
  .prompt:hover {
    border-color: var(--color-accent);
    color: var(--color-fg);
    background: var(--color-surface-2);
  }
  .prompt:hover .prompt-cursor { color: var(--color-accent); }

  .prompt-cursor {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 500;
    transform: translateY(-0.5px);
  }
  .prompt-label { flex: 1; }
  .prompt-key {
    color: var(--color-quiet);
    font-size: 11px;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .prompt-key kbd {
    font-family: inherit;
    border: 1px solid var(--color-hairline);
    border-radius: 3px;
    padding: 0 5px;
    background: rgb(0 0 0 / 0.3);
    color: var(--color-muted);
  }

  /* ----- Portrait ----- */

  :global(.home-portrait) {
    align-self: end;
    width: clamp(160px, 22vw, 280px);
    opacity: 0;
    animation: fade-up 700ms cubic-bezier(0.5, 0, 0.2, 1) 700ms both;
  }

  /* ----- Animations ----- */

  @keyframes rise {
    to { transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-signal {
    0%, 100% { box-shadow: 0 0 6px rgb(91 168 155 / 0.45); opacity: 1; }
    50%      { box-shadow: 0 0 12px rgb(91 168 155 / 0.85); opacity: 0.75; }
  }

  @media (prefers-reduced-motion: reduce) {
    .meta, .hero-title .line-inner, .hero-sub .line-inner, .prompt, :global(.home-portrait) {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .meta .dot { animation: none; }
  }

  /* ----- Responsive ----- */

  @media (min-width: 721px) and (max-width: 1024px) {
    .home {
      align-items: center;
      min-height: auto;
      padding-block: clamp(3rem, 10vh, 6rem);
    }
  }

  @media (max-width: 720px) {
    .home {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      align-items: start;
      gap: 2rem;
      min-height: calc(100vh - 180px);
      padding: 2rem 1.25rem 3rem;
    }
    .hero { gap: 1.5rem; }
    .hero-sub { max-width: 26ch; }
    .prompt { min-width: 0; width: 100%; }
    .prompt-key { display: none; }
    :global(.home-portrait) {
      align-self: end;
      justify-self: end;
    }
  }

  @media (hover: none) {
    .prompt-key { display: none; }
  }
</style>
