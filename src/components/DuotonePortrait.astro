---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  caption: string;
  year: string;
  film?: string;
  shutter?: string;
  objectPosition?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  src,
  alt = '',
  caption,
  year,
  film = 'PORTRA 400',
  shutter = '1/250s',
  objectPosition = '50% 28%',
  ariaLabel = 'Portrait',
  class: className,
} = Astro.props;

const filmDisplay = film.replace(/ /g, ' ');
---

<aside class:list={['duotone', className]} aria-label={ariaLabel}>
  <figure>
    <div class="frame">
      <span class="glow" aria-hidden="true"></span>
      <Image
        src={src}
        alt={alt}
        width={960}
        height={1200}
        widths={[420, 560, 720, 960]}
        sizes="(max-width: 720px) 78vw, (max-width: 1024px) 38vw, 460px"
        loading="eager"
        class="img"
        style={`object-position: ${objectPosition};`}
      />
      <span class="corner tl" aria-hidden="true"></span>
      <span class="corner tr" aria-hidden="true"></span>
      <span class="corner bl" aria-hidden="true"></span>
      <span class="corner br" aria-hidden="true"></span>
      <span class="stamp" aria-hidden="true">
        <span>{filmDisplay}</span>
        <span class="stamp-sep">·</span>
        <span>{shutter}</span>
      </span>
    </div>
    <figcaption class="cap">
      <span>{caption}</span>
      <span class="cap-sep">/</span>
      <span>{year}</span>
    </figcaption>
  </figure>
</aside>

<style>
  .duotone figure { margin: 0; }

  .frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: linear-gradient(168deg, #C68F45 0%, #2A1B07 60%, #0F0A03 100%);
    isolation: isolate;
    box-shadow:
      0 30px 70px -28px rgb(0 0 0 / 0.7),
      0 0 0 1px var(--color-hairline),
      inset 0 0 0 1px rgb(255 255 255 / 0.03);
  }

  .glow {
    position: absolute;
    inset: -22%;
    background: radial-gradient(50% 50% at 30% 35%, rgb(232 168 58 / 0.32) 0%, transparent 70%);
    filter: blur(28px);
    z-index: -1;
    opacity: 0.85;
  }

  .img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.85) contrast(1.02) brightness(1.04) saturate(1.05);
    mix-blend-mode: lighten;
    transition: filter 700ms ease, transform 1.6s cubic-bezier(0.2, 0.7, 0, 1);
    transform: scale(1.02);
  }
  .duotone:hover .img {
    filter: grayscale(0.7) contrast(1.02) brightness(1.08) saturate(1.1);
    transform: scale(1.0);
  }

  .corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--color-fg);
    opacity: 0.55;
    z-index: 2;
  }
  .corner.tl { top: 8px; left: 8px;  border-top: 1px solid; border-left: 1px solid; }
  .corner.tr { top: 8px; right: 8px; border-top: 1px solid; border-right: 1px solid; }
  .corner.bl { bottom: 8px; left: 8px;  border-bottom: 1px solid; border-left: 1px solid; }
  .corner.br { bottom: 8px; right: 8px; border-bottom: 1px solid; border-right: 1px solid; }

  .stamp {
    position: absolute;
    bottom: 14px;
    left: 14px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(240 235 226 / 0.62);
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.7);
  }
  .stamp-sep { opacity: 0.55; }

  .cap {
    margin: 0.85rem 0 0;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-quiet);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }
  .cap-sep { opacity: 0.5; }

  @media (prefers-reduced-motion: reduce) {
    .img { transition: none; transform: none; }
  }
</style>
