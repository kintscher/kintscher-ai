---
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const isContact = path === '/contact' || path.startsWith('/contact/');
---

<footer class="site-footer">
  <div class="row">
    <span class="pair">
      <span class="muted">kintscher.ai</span>
      <span class="sep" aria-hidden="true">/</span>
      <span class="muted">© {year}</span>
    </span>
    <span class="sep wide-only" aria-hidden="true">/</span>
    <span class="pair">
      <span class="muted">47.37°N&nbsp;8.54°E</span>
      <span class="sep" aria-hidden="true">/</span>
      <span class="muted">Zürich</span>
    </span>
    <span class="grow"></span>
    <a
      href="/contact"
      class:list={['contact-link', { current: isContact }]}
      aria-current={isContact ? 'page' : undefined}
    >
      <span>contact</span>
      <span class="key-hint" aria-hidden="true">⌐&nbsp;X</span>
    </a>
  </div>
</footer>

<style>
  .site-footer {
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--color-hairline);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .pair {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    white-space: nowrap;
  }

  .muted { color: var(--color-quiet); }
  .sep   { color: var(--color-quiet); opacity: 0.55; }
  .grow  { flex: 1; }

  .contact-link {
    color: var(--color-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    transition: color 150ms ease;
    position: relative;
  }
  .contact-link:hover { color: var(--color-fg); }
  .contact-link.current { color: var(--color-fg); }
  .contact-link.current::before {
    content: '';
    position: absolute;
    left: -0.85rem;
    top: 0.5em;
    width: 4px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 999px;
  }

  @media (max-width: 720px) {
    .site-footer { padding: 1.25rem 1.25rem; }
    .grow { display: none; }
    .key-hint { display: none; }
  }

  @media (max-width: 480px) {
    .row {
      gap: 0.5rem 0.6rem;
    }
    .wide-only { display: none; }
    .contact-link {
      padding: 0.5rem 0;
      margin-left: auto;
    }
  }
</style>
