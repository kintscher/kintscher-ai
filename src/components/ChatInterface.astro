---
type Suggestion = { text: string };

const suggestions: Suggestion[] = [
  { text: "what's yannik's background?" },
  { text: "what's he working on right now?" },
  { text: "what's his stack?" },
];
---

<div class="chat-shell">
  <div class="chat-prelude">
    <h1 class="chat-invitation">Ask anything about Yannik.</h1>

    <ul class="chat-chips" aria-label="Suggested questions">
      {suggestions.map((s) => (
        <li>
          <button type="button" class="chat-chip" data-suggestion={s.text}>
            <span class="chip-prompt" aria-hidden="true">›</span>
            <span class="chip-text">{s.text}</span>
          </button>
        </li>
      ))}
    </ul>
  </div>

  <div class="chat-form-area">
    <form class="chat-form" id="chat-form" autocomplete="off" novalidate>
      <span class="chat-prompt" aria-hidden="true">›</span>
      <div class="chat-input-wrap">
        <input
          id="chat-input"
          name="message"
          type="text"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder=" "
          aria-label="Ask anything about Yannik"
        />
        <span class="chat-caret" aria-hidden="true"></span>
      </div>
      <button type="submit" class="chat-submit" aria-label="Send">
        <span class="submit-label" aria-hidden="true">send</span>
        <kbd class="submit-key" aria-hidden="true">↵</kbd>
      </button>
    </form>

    <p class="chat-privacy">
      Conversations are not stored. Powered by Claude.
    </p>
  </div>
</div>

<script>
  type ChatWindow = Window & { __kChatBound?: boolean };
  const w = window as ChatWindow;

  function setup() {
    const form  = document.getElementById('chat-form')  as HTMLFormElement | null;
    const input = document.getElementById('chat-input') as HTMLInputElement | null;
    if (!form || !input) return;

    function stub(message: string) {
      // eslint-disable-next-line no-console
      console.log({ message });
      input!.value = '';
      input!.focus();
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const value = input.value.trim();
      if (!value) return;
      stub(value);
    });

    document.querySelectorAll<HTMLButtonElement>('.chat-chip').forEach((chip) => {
      if (chip.dataset.chipBound) return;
      chip.dataset.chipBound = '1';
      chip.addEventListener('click', () => {
        const text = chip.dataset.suggestion ?? '';
        input.value = text;
        stub(text);
      });
    });

    if (!w.__kChatBound) {
      w.__kChatBound = true;
    }
  }

  setup();
  document.addEventListener('astro:page-load', setup);
</script>

<style>
  .chat-shell {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
    min-height: calc(100vh - 180px);
    padding: clamp(1.5rem, 4vh, 3rem) 2rem clamp(1rem, 3vh, 2rem);
    gap: clamp(1.5rem, 4vh, 2.5rem);
  }

  .chat-prelude {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.25rem, 3vh, 2rem);
  }

  /* ----- Invitation (h1) ----- */

  .chat-invitation {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.875rem, 4.2vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    opacity: 0;
    animation: chat-rise 600ms cubic-bezier(0.2, 0.7, 0, 1) 80ms both;
  }

  /* ----- Suggested-question chips ----- */

  .chat-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-start;
  }
  .chat-chips li {
    opacity: 0;
    animation: chat-rise 520ms cubic-bezier(0.2, 0.7, 0, 1) both;
  }
  .chat-chips li:nth-child(1) { animation-delay: 220ms; }
  .chat-chips li:nth-child(2) { animation-delay: 300ms; }
  .chat-chips li:nth-child(3) { animation-delay: 380ms; }

  .chat-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    background: transparent;
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    padding: 0.5rem 0.85rem 0.5rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.3;
    color: var(--color-muted);
    cursor: pointer;
    text-align: left;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
  }
  .chat-chip:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-fg);
  }
  .chat-chip .chip-prompt {
    color: var(--color-accent);
    font-weight: 500;
    transform: translateY(-0.5px);
  }
  .chat-chip .chip-text { flex: 1; }

  /* ----- Form area ----- */

  .chat-form-area {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    opacity: 0;
    animation: chat-rise 520ms cubic-bezier(0.2, 0.7, 0, 1) 460ms both;
  }

  .chat-form {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: 8px;
    padding: 0.7rem 0.85rem 0.7rem 0.95rem;
    font-family: var(--font-mono);
    font-size: 14px;
    transition: border-color 180ms ease, background 180ms ease;
  }
  .chat-form:focus-within {
    border-color: var(--color-hairline-strong);
    background: var(--color-surface-2);
  }

  .chat-prompt {
    color: var(--color-accent);
    font-weight: 500;
    transform: translateY(-1px);
    flex-shrink: 0;
  }

  .chat-input-wrap {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
  }

  #chat-input {
    flex: 1;
    width: 100%;
    background: transparent;
    border: none;
    color: var(--color-fg);
    font: inherit;
    padding: 0;
    caret-color: var(--color-accent);
    min-width: 0;
  }
  #chat-input::placeholder { color: var(--color-quiet); }

  /* Custom soft-pulsing caret in the empty state.
     Native caret is hidden when empty so the two don't collide;
     once the user types, native amber caret takes over. */
  #chat-input:placeholder-shown { caret-color: transparent; }
  .chat-caret {
    position: absolute;
    left: 0;
    top: 50%;
    width: 2px;
    height: 1.05em;
    background: var(--color-accent);
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0;
    box-shadow: 0 0 6px rgb(232 168 58 / 0.45);
  }
  .chat-form:has(#chat-input:placeholder-shown) .chat-caret {
    opacity: 1;
    animation: chat-caret-pulse 1.4s ease-in-out infinite;
  }

  .chat-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    padding: 0.25rem 0.5rem 0.25rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-quiet);
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
    flex-shrink: 0;
  }
  .chat-submit:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgb(232 168 58 / 0.05);
  }
  .submit-key {
    font-family: inherit;
    color: inherit;
    opacity: 0.85;
  }

  /* ----- Privacy footnote ----- */

  .chat-privacy {
    margin: 0;
    padding: 0 0.25rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-quiet);
  }

  /* ----- sr-only ----- */

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  /* ----- Animations ----- */

  @keyframes chat-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes chat-caret-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.25; }
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-invitation,
    .chat-chips li,
    .chat-form-area {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .chat-caret { animation: none; }
    .chat-chip { transition: none; }
    .chat-form { transition: none; }
    .chat-submit { transition: none; }
  }

  /* ----- Responsive ----- */

  @media (max-width: 720px) {
    .chat-shell {
      padding: 1.25rem 1.25rem 1rem;
      min-height: calc(100vh - 160px);
      gap: 1.25rem;
    }
    .chat-chips { width: 100%; }
    .chat-chip {
      width: 100%;
      font-size: 12.5px;
    }
    .chat-form { padding: 0.65rem 0.7rem 0.65rem 0.85rem; }
    .submit-label { display: none; }
  }
</style>
