{
	"compatibility_date": "2026-04-16",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "kintscher-ai",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "CHAT_RATE_LIMIT",
			"id": "e51f0b08292645c691b7d86a596be66e",
			"remote": true
		}
	]
}